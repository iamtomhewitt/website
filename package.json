{
  "name": "website",
  "version": "2.0.2",
  "author": "Tom Hewitt",
  "scripts": {
    "build": "rm -rf dist && tsc -b && vite build",
    "deploy": "gh-pages -d dist",
    "lint": "retail-linter --sourceFolder=./ --type=typescript-react",
    "lint-fix": "retail-linter --sourceFolder=./ --type=typescript-react --fix",
    "predeploy": "npm run build",
    "prepare": "husky",
    "release": "ts-node --esm release.ts && npm run deploy",
    "start": "vite --host"
  },
  "dependencies": {
    "classnames": "2.5.1",
    "gh-pages": "6.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-responsive": "10.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "date-fns": "4.1.0",
    "husky": "9.1.7",
    "retail-linter": "3.4.0",
    "sass-embedded": "1.99.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vite-plugin-svgr": "4.5.0"
  }
}